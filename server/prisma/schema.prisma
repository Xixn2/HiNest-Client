// HiNest database schema
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // RDS 로 이전한 뒤부터는 pgBouncer 가 없어서 런타임/마이그레이션 모두 동일 URL 사용.
  // 과거 Supabase 때는 directUrl 로 pgBouncer 우회 포트(5432) 를 따로 지정했었음.
  url = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String
  // 총관리자 전용 step-up 비밀번호 (일반 로그인 비밀번호와 분리).
  // null 이면 일반 비밀번호로 fallback (초기 설정용).
  superPasswordHash String?
  role         String   @default("MEMBER") // ADMIN | MANAGER | MEMBER
  superAdmin   Boolean  @default(false)    // 최상위 관리자 - DM/팀 채팅 감사 권한 보유
  position     String?  // 사원/대리/과장/팀장/이사 등
  team         String?
  active       Boolean  @default(true)
  // 퇴사일 — 관리자가 "퇴사 처리" 하면 set. 동시에 active=false 로 로그인 차단.
  // null 이면 재직 중. 날짜(YYYY-MM-DD) 가 아니라 DateTime 으로 두어 정렬/기간 조회 편의성 확보.
  resignedAt   DateTime?
  avatarColor  String   @default("#36D7B7")
  /// 업로드된 프로필 이미지 URL. null 이면 avatarColor + 이니셜 fallback.
  avatarUrl    String?
  // HR 상세 (엑셀 업/다운로드용) — 모두 선택값.
  hrCode             String?  // HR번호 (daiso_worker46 등)
  affiliation        String?  // 소속 (예: 다이소)
  employeeNo         String?  // 사번 (AD6156258 등)
  workplace          String?  // 근무지 (본사/지점 등)
  department         String?  // 부서 (team 과 별개로 유지)
  jobDuty            String?  // 직무
  employmentType     String?  // 고용형태 (정규직/계약직)
  employmentCategory String?  // 고용유형 (유기계약 등)
  contractType       String?  // 계약형태 (기간제 등)
  birthDate          String?  // 생년월일 YYYY-MM-DD
  gender             String?  // 남/여
  disabilityType     String?  // 장애유형
  disabilityLevel    String?  // 장애정도 (중증/경증)
  hireDate           String?  // 입사일 YYYY-MM-DD
  phone              String?  // 전화번호
  note               String?  // 비고
  // 자동 퇴근 시간 ("HH:mm", Asia/Seoul 기준).
  // 설정돼있으면 매일 이 시간이 됐을 때 오늘 출근 기록(checkIn 존재, checkOut null)에 대해
  // 서버 스케줄러가 checkOut 을 그 시각으로 기록한다. null 이면 자동 퇴근 없음.
  autoClockOutTime   String?
  // 사용자 업무 상태 — AVAILABLE(근무중) | MEETING | MEAL | OUT | OFFLINE | AWAY
  // null 이면 attendance 기준으로 "출근/퇴근/미출근" 자동 판정
  presenceStatus    String?
  presenceMessage   String?
  presenceUpdatedAt DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  inviteKey    InviteKey? @relation("UsedKey")
  events       Event[]
  leaves       Leave[]
  attendances  Attendance[]
  journals     Journal[]
  notices      Notice[]
  messagesSent ChatMessage[]    @relation("Sender")
  memberships  RoomMember[]
  logs         AuditLog[]
  cardExpenses CardExpense[]
  notifications Notification[]
  documents    Document[]       @relation("DocumentAuthor")
  approvalsRequested Approval[] @relation("ApprovalRequester")
  approvalReviews    ApprovalStep[] @relation("ApprovalReviewer")
  passkeys     Passkey[]
  desktopBios  DesktopBiometric[]
  reactions    MessageReaction[]
  projects     ProjectMember[]
  projectsCreated Project[] @relation("ProjectCreator")
  meetings     Meeting[]        @relation("MeetingAuthor")
  meetingViews MeetingViewer[]
}

/// 팀/프로젝트 — 사이드바 "팀" 카테고리 아래에 자신이 참여중인 프로젝트가 표시됨.
/// 멤버는 ProjectMember 로 연결, 생성자는 자동으로 OWNER 로 들어감.
model Project {
  id          String           @id @default(cuid())
  name        String
  description String?
  color       String           @default("#3B5CF0")
  status      String           @default("ACTIVE") // ACTIVE | ARCHIVED
  createdById String
  createdBy   User             @relation("ProjectCreator", fields: [createdById], references: [id], onDelete: Cascade)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  members     ProjectMember[]
  events      ProjectEvent[]
  webhooks    WebhookChannel[]
  meetings    Meeting[]
  documents   Document[]
  folders     Folder[]
  qaItems     ProjectQaItem[]
  // 전사 캘린더(Event) 중 이 프로젝트 범위로 공유된 일정
  scheduleEvents Event[]
}

/// 프로젝트별 QA(테스트) 체크리스트 — "무엇을 검증했고 결과가 어땠는지" 남기는 용도.
/// 기능 배포 전 점검 · 버그 재현/픽스 이력 · 수기 테스트 기록에 쓰임.
model ProjectQaItem {
  id           String    @id @default(cuid())
  projectId    String
  project      Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title        String
  /// 상세 메모 — 재현 스텝/기대 결과/비고 등 자유 서식
  note         String?
  /// 문제가 발생한 화면/위치 라벨 (예: "로그인 페이지", "모바일 > 설정 > 프로필")
  screen       String?
  /// 재현 플랫폼 — WEB | IOS | ANDROID | MAC_APP | WINDOWS_APP | OTHER
  platform     String?
  /// 이 이슈를 수정/담당할 사람 (프로젝트 멤버 중 선택). 해지는 null.
  assigneeId   String?
  /// BUG | IN_PROGRESS | DONE | ON_HOLD — 오류/수정 중/완료/보류
  status       String    @default("BUG")
  /// LOW | NORMAL | HIGH
  priority     String    @default("NORMAL")
  /// 리스트 수동 정렬용 — 값이 같으면 createdAt 기준.
  sortOrder    Int       @default(0)
  createdById  String
  /// 상태를 OPEN → PASSED/FAILED/SKIPPED 로 바꾼 사람/시각 (감사 이력).
  resolvedById String?
  resolvedAt   DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  attachments  ProjectQaAttachment[]

  @@index([projectId, status])
  @@index([projectId, sortOrder])
  @@index([projectId, assigneeId])
}

/// QA 항목에 첨부된 이미지/영상/파일. 업로드는 공용 `/api/upload` 를 거쳐
/// 반환된 url/metadata 를 그대로 이 레코드에 저장해둠.
model ProjectQaAttachment {
  id         String   @id @default(cuid())
  qaItemId   String
  qaItem    ProjectQaItem @relation(fields: [qaItemId], references: [id], onDelete: Cascade)
  /// 업로드 후 내려받을 수 있는 URL (`/uploads/<key>` 형식)
  url        String
  /// 원본 파일명 (한글 포함)
  name       String
  /// MIME 타입 — 썸네일/재생 분기에 쓰임
  mimeType   String
  sizeBytes  Int
  /// IMAGE | VIDEO | FILE — 클라이언트 렌더 분기 편의를 위해 사전 계산해 저장
  kind       String
  uploadedById String
  createdAt  DateTime @default(now())

  @@index([qaItemId, createdAt])
}

/// 외부 서비스에서 들어오는 웹훅 이벤트를 받아 프로젝트 안 "채널"로 묶어 노출.
/// token 은 URL 경로에 들어가 비밀 키 역할 — 외부로 노출되므로 rotate 가능하게 저장.
model WebhookChannel {
  id          String   @id @default(cuid())
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name        String
  description String?
  color       String   @default("#6366F1")
  /// URL 경로용 secret token — `/api/webhook/:token` 로 외부에서 POST
  token       String   @unique
  /// (선택) HMAC-SHA256 서명 검증용 시크릿. 지정 시 요청에 반드시 X-Signature: sha256=<hex>
  /// 가 있어야 수락. raw body 기준으로 서명.
  signingSecret String?
  createdById String
  createdAt   DateTime @default(now())
  events      WebhookEvent[]

  @@index([projectId])
}

model WebhookEvent {
  id         String   @id @default(cuid())
  channelId  String
  channel    WebhookChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  /// 추출된 제목 — 기본은 payload.title / payload.subject / payload.text 첫줄.
  title      String
  /// 추출된 본문 (길이 제한)
  body       String?
  /// 원본 JSON 문자열 — 디버깅/리플레이 용
  rawPayload String
  /// 요청 발신 IP (X-Forwarded-For 우선)
  sourceIp   String?
  createdAt  DateTime @default(now())

  @@index([channelId, createdAt])
}

model ProjectMember {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      String   @default("MEMBER") // OWNER | MANAGER | MEMBER
  joinedAt  DateTime @default(now())

  @@unique([projectId, userId])
  @@index([userId])
}

/// 프로젝트 전용 일정 — 회사 전체 일정(Event) 과 분리. 월/주/일 뷰에서 쓰임.
model ProjectEvent {
  id          String   @id @default(cuid())
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title       String
  description String?
  startAt     DateTime
  endAt       DateTime
  allDay      Boolean  @default(false)
  color       String   @default("#3B5CF0")
  // 담당자 userId 콤마 구분 — 해당 프로젝트 멤버에 한해 선택.
  assigneeIds String?
  /// 완료 여부. UI 에서 체크박스로 토글.
  /// completedAt/completedById 는 completed=true 로 전환 시 자동 기록 — 누가 언제 완료했는지 감사용.
  completed     Boolean   @default(false)
  completedAt   DateTime?
  completedById String?
  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([projectId, startAt])
}

/// Electron 데스크톱 앱에서 OS Touch ID 로 총관리자 잠금 해제할 수 있게 등록된 기기.
/// Chromium WebAuthn 이 Electron 에서 플랫폼 인증기를 노출하지 않기 때문에 별도 관리.
model DesktopBiometric {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  deviceId   String   // Electron 이 userData 폴더에 생성한 안정적인 기기 UUID
  deviceName String?
  createdAt  DateTime @default(now())
  lastUsedAt DateTime?

  @@unique([userId, deviceId])
  @@index([userId])
}

model Passkey {
  id           String    @id @default(cuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  credentialId String    @unique
  publicKey    Bytes
  counter      Int       @default(0)
  transports   String?
  deviceName   String?
  createdAt    DateTime  @default(now())
  lastUsedAt   DateTime?

  @@index([userId])
}

model InviteKey {
  id          String    @id @default(cuid())
  key         String    @unique
  email       String?
  name        String?
  role        String    @default("MEMBER")
  team        String?
  position    String?
  used        Boolean   @default(false)
  usedAt      DateTime?
  usedById    String?   @unique
  usedBy      User?     @relation("UsedKey", fields: [usedById], references: [id])
  createdById String?
  createdAt   DateTime  @default(now())
  expiresAt   DateTime?
}

model Event {
  id            String   @id @default(cuid())
  title         String
  content       String?
  scope         String   @default("COMPANY") // COMPANY | TEAM | PROJECT | PERSONAL | TARGETED
  team          String?
  /// scope=PROJECT 인 경우 연결된 프로젝트. 해당 프로젝트 멤버만 열람/수정.
  /// 프로젝트 삭제 시 일정도 함께 제거.
  projectId     String?
  project       Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)
  category      String   @default("OTHER") // MEETING | DEADLINE | OUT | HOLIDAY | EVENT | BIRTHDAY | TASK | OTHER
  targetUserIds String?  // comma separated userIds (scope=TARGETED or mention targets)
  startAt       DateTime
  endAt         DateTime
  color         String   @default("#3B5CF0")
  createdBy     String
  author        User     @relation(fields: [createdBy], references: [id], onDelete: Cascade)
  createdAt     DateTime @default(now())

  // 월별 캘린더 조회 — 대부분의 read 경로.
  @@index([startAt, endAt])
  @@index([projectId, startAt])
}

model Leave {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String   // ANNUAL | HALF | SICK | OTHER
  startDate DateTime
  endDate   DateTime
  reason    String?
  status    String   @default("PENDING") // PENDING | APPROVED | REJECTED
  reviewer  String?
  createdAt DateTime @default(now())

  @@index([userId, status])
}

model Attendance {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date      String   // YYYY-MM-DD
  checkIn   DateTime?
  checkOut  DateTime?
  note      String?

  @@unique([userId, date])
  // 디렉터리 페이지가 "오늘 date + userId IN (...)" 로 묶어 조회 →
  // unique 가 만드는 (userId, date) 순서로는 date 선두 조회가 안 되므로 역순 인덱스 추가.
  @@index([date, userId])
}

model Journal {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date      String   // YYYY-MM-DD
  title     String
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, date(sort: Desc)])
}

model Notice {
  id        String   @id @default(cuid())
  title     String
  content   String
  pinned    Boolean  @default(false)
  authorId  String
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([pinned(sort: Desc), createdAt(sort: Desc)])
}

model ChatRoom {
  id        String        @id @default(cuid())
  name      String
  type      String        @default("GROUP") // GROUP | DIRECT | TEAM
  createdAt DateTime      @default(now())
  members   RoomMember[]
  messages  ChatMessage[]
}

model RoomMember {
  id         String    @id @default(cuid())
  roomId     String
  userId     String
  lastReadAt DateTime?
  room       ChatRoom  @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([roomId, userId])
  // userId 단독 조회 — "내가 속한 방" 검색에서 자주 쓰임
  @@index([userId])
}

model ChatMessage {
  id          String    @id @default(cuid())
  roomId      String
  senderId    String
  content     String
  kind        String    @default("TEXT") // TEXT | IMAGE | VIDEO | FILE
  fileUrl     String?
  fileName    String?
  fileType    String?
  fileSize    Int?
  mentions    String?   // comma-separated userIds
  editedAt    DateTime?
  deletedAt   DateTime?
  scheduledAt DateTime?
  pinnedAt    DateTime?
  pinnedById  String?
  createdAt   DateTime  @default(now())
  room        ChatRoom  @relation(fields: [roomId], references: [id], onDelete: Cascade)
  sender      User      @relation("Sender", fields: [senderId], references: [id], onDelete: Cascade)
  reactions   MessageReaction[]

  @@index([roomId, scheduledAt])
  // after-cursor 증분 폴링 — createdAt 역정렬·범위 조회가 핵심 경로
  @@index([roomId, createdAt])
}

model MessageReaction {
  id        String      @id @default(cuid())
  messageId String
  message   ChatMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  userId    String
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  emoji     String
  createdAt DateTime    @default(now())

  @@unique([messageId, userId, emoji])
  @@index([messageId])
}

model Team {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())
}

model Position {
  id        String   @id @default(cuid())
  name      String   @unique
  rank      Int      @default(0)
  createdAt DateTime @default(now())
}

model CardExpense {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  usedAt     DateTime
  merchant   String
  category   String   // 식비 | 교통 | 업무 | 접대 | 비품 | 기타
  amount     Int
  memo       String?
  receiptUrl String?  // base64 데이터 URL 또는 외부 링크
  status     String   @default("PENDING") // PENDING | APPROVED | REJECTED
  reviewer   String?
  createdAt  DateTime @default(now())

  @@index([userId, usedAt(sort: Desc)])
}

model Notification {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String    // NOTICE | DM | APPROVAL_REQUEST | APPROVAL_REVIEW | MENTION | SYSTEM
  title     String
  body      String?
  linkUrl   String?
  actorName String?   // 알림 유발자 이름 (ex. 메시지 발신자)
  actorColor String?
  readAt    DateTime?
  createdAt DateTime  @default(now())

  // 미읽음 필터용 — (userId, readAt=null) 부분 빠른 조회.
  @@index([userId, readAt])
  // 리스트 페이지 — 최신순 정렬이 핵심이라 (userId, createdAt desc) 인덱스 추가.
  @@index([userId, createdAt(sort: Desc)])
}

model Folder {
  id        String     @id @default(cuid())
  name      String
  parentId  String?
  parent    Folder?    @relation("FolderChildren", fields: [parentId], references: [id], onDelete: Cascade)
  children  Folder[]   @relation("FolderChildren")
  documents Document[]
  // 폴더 공개 범위 — Document 의 scope 와 동일 의미.
  // ALL(전체) | TEAM(팀) | PRIVATE(개인) | CUSTOM(사용자지정)
  // 탭별로 구분되어 보이도록 추가. authorId 는 PRIVATE / 권한 판단용.
  scope        String  @default("ALL")
  scopeTeam    String?
  scopeUserIds String? // CUSTOM 일 때 접근 허용 유저 id 콤마 구분
  authorId     String?
  // 프로젝트 문서함 전용 폴더. null 이면 전역 문서함.
  // projectId 가 있으면 visibility 는 ProjectMember 기준으로 판단 (scope 필드는 무시됨).
  projectId String?
  project   Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt DateTime   @default(now())

  @@index([projectId])
}

model Document {
  id          String   @id @default(cuid())
  title       String
  description String?
  folderId    String?
  folder      Folder?  @relation(fields: [folderId], references: [id], onDelete: SetNull)
  fileUrl     String?
  fileName    String?
  fileType    String?
  fileSize    Int?
  tags        String?  // comma separated
  authorId    String
  author      User     @relation("DocumentAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  // 공개 범위 — ALL(전체) | TEAM(팀) | PRIVATE(개인) | CUSTOM(사용자지정)
  scope        String  @default("ALL")
  scopeTeam    String? // TEAM 일 때 대상 팀명
  scopeUserIds String? // CUSTOM 일 때 접근 허용 유저 id 콤마 구분
  // 프로젝트 문서함 전용 문서. null 이면 전역 문서함.
  // projectId 가 있으면 가시성은 ProjectMember 기준 (scope 는 무시됨).
  projectId String?
  project   Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([projectId, updatedAt])
}

model Approval {
  id          String   @id @default(cuid())
  type        String   // TRIP | EXPENSE | PURCHASE | GENERAL | OFFSITE | OTHER
  title       String
  content     String?
  data        String?  // JSON
  status      String   @default("PENDING") // PENDING | APPROVED | REJECTED | CANCELED
  requesterId String
  requester   User     @relation("ApprovalRequester", fields: [requesterId], references: [id], onDelete: Cascade)
  startDate   DateTime?
  endDate     DateTime?
  amount      Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  steps       ApprovalStep[]

  @@index([requesterId, createdAt(sort: Desc)])
}

model ApprovalStep {
  id         String   @id @default(cuid())
  approvalId String
  approval   Approval @relation(fields: [approvalId], references: [id], onDelete: Cascade)
  reviewerId String
  reviewer   User     @relation("ApprovalReviewer", fields: [reviewerId], references: [id], onDelete: Cascade)
  order      Int
  status     String   @default("PENDING") // PENDING | APPROVED | REJECTED | SKIPPED
  comment    String?
  actedAt    DateTime?

  @@unique([approvalId, order])
  @@index([reviewerId, status])
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action    String
  target    String?
  detail    String?
  ip        String?
  createdAt DateTime @default(now())

  @@index([createdAt(sort: Desc)])
}

/// 회의록 — 노션 스타일 리치 텍스트 에디터(TipTap) 의 JSON 도큐먼트를 content 에 저장.
/// 공개 범위:
///   ALL       전사 — 로그인한 누구나 읽기
///   PROJECT   특정 프로젝트 멤버만 (projectId 필수)
///   SPECIFIC  선택된 개별 유저만 (viewers 릴레이션)
/// 작성자는 무조건 조회·수정 가능. ADMIN 은 전역 열람.
model Meeting {
  id          String            @id @default(cuid())
  title       String
  /// TipTap JSON document. HTML 이 아닌 구조화된 노드 트리.
  content     Json
  visibility  String            @default("ALL") // ALL | PROJECT | SPECIFIC
  projectId   String?
  project     Project?          @relation(fields: [projectId], references: [id], onDelete: SetNull)
  authorId    String
  author      User              @relation("MeetingAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  viewers     MeetingViewer[]
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@index([authorId, createdAt])
  @@index([projectId, createdAt])
}

/// visibility=SPECIFIC 인 회의록에서 열람 허용된 유저.
model MeetingViewer {
  id        String  @id @default(cuid())
  meetingId String
  meeting   Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  userId    String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([meetingId, userId])
  @@index([userId])
}
