{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "release-type": "node",
  "packages": {
    ".": {
      "package-name": "hinest",
      "changelog-path": "CHANGELOG.md",
      "include-component-in-tag": false,
      "extra-files": [
        { "type": "json", "path": "client/package.json", "jsonpath": "$.version" },
        { "type": "json", "path": "server/package.json", "jsonpath": "$.version" }
      ]
    }
  },
  "changelog-sections": [
    { "type": "feat",     "section": "🚀 Features" },
    { "type": "fix",      "section": "🐛 Bug Fixes" },
    { "type": "perf",     "section": "⚡ Performance" },
    { "type": "refactor", "section": "♻️ Refactor" },
    { "type": "docs",     "section": "📝 Docs",     "hidden": true },
    { "type": "test",     "section": "✅ Tests",    "hidden": true },
    { "type": "build",    "section": "📦 Build",    "hidden": true },
    { "type": "ci",       "section": "🤖 CI",       "hidden": true },
    { "type": "chore",    "section": "🧹 Chore",    "hidden": true },
    { "type": "style",    "section": "💄 Style",    "hidden": true }
  ],
  "bump-minor-pre-major": true,
  "bump-patch-for-minor-pre-major": true,
  "draft": false,
  "prerelease": false,
  "pull-request-title-pattern": "chore${scope}: release ${version}",
  "pull-request-header": "🎁 다음 릴리즈 후보 — 머지하면 태그와 GitHub Release 가 자동 생성됩니다."
}
